## Copy this file to .env and fill in your credentials.
## Every variable below notes its (default: …). Commented-out lines show the
## default/example value; uncomment to change. After editing run:
##   docker compose --profile easynews-indexer up -d   (no rebuild needed)

## Easynews account. (default: none — REQUIRED, the server won't start without them)
EASYNEWS_USER=your_easynews_username
EASYNEWS_PASS=your_easynews_password

## API key Prowlarr/NZBHydra/Newznab clients use to authenticate to THIS server.
## Change it from the default. (default: testkey)
NEWZNAB_APIKEY=testkey

## Port the server listens on. (default: 8081)
PORT=8081

## ──────────────────────────────────────────────────────────────────────────
## Latency / hedging (read at container start)
## ──────────────────────────────────────────────────────────────────────────
## Hard cap on total time per search. Keep it below NZBHydra's indexer timeout
## (4 s). Raise only if you also raise Hydra's timeout. (default: 3.3)
SEARCH_BUDGET_SECONDS=3.3

## If Easynews hasn't answered within this, fire a parallel "hedge" request. Set
## it near your typical Easynews response time. Lower = recover from slow
## responses faster (more parallel load); higher = hedge less often. (default: 1.2)
SEARCH_HEDGE_AFTER_SECONDS=1.2

## Per-request read timeout in seconds — aborts a single hung connection.
## (default: 2.5)
SEARCH_ATTEMPT_TIMEOUT_SECONDS=2.5

## Treat a fast, successful "0 results" as final and return immediately, instead
## of retrying 3x and idling out the budget (a real hang is an error, not an
## empty, and still retries). Keeps no-result queries ~0.3s instead of ~3.3s.
## Set false to restore the old 3-try-on-empty behaviour. (default: true)
# SEARCH_TRUST_EMPTY=true

## Keepalive — a background thread holds a warm TLS connection to Easynews open
## during idle gaps so the next real search skips the cold handshake. Set false
## to turn it off entirely (e.g. to minimise idle account activity); searches
## then just pay the handshake cost on the first request after an idle gap.
## (default: true)
# EASYNEWS_KEEPALIVE=true
## How often the keepalive thread wakes, and how many idle seconds (no real
## search traffic) must pass before it actually pings. (defaults: 45 / 40)
# EASYNEWS_KEEPALIVE_INTERVAL_SECONDS=45
# EASYNEWS_KEEPALIVE_IDLE_SECONDS=40

## Skip season-pack searches (a season with NO episode, e.g. "The Boys S05").
## Easynews rarely has real season packs, so enabling this stops them from
## polluting season searches — the query returns no results without hitting
## Easynews. Episode searches (S05E01) and movie searches are unaffected.
## (default: false — this file sets it true as a recommendation)
IGNORE_SEASON_PACKS=true

## ──────────────────────────────────────────────────────────────────────────
## Search endpoint selection (for A/B benchmarking endpoint speed)
## ──────────────────────────────────────────────────────────────────────────
## Which Easynews search endpoint to use:
##   2.0 → /2.0/search/solr-search/  (proven)
##   3.0 → /3.0/api/search           (newer JSON api; leaner payload, ~3x smaller)
## (default: 2.0)
EASYNEWS_SEARCH_API=3.0

## Override the Easynews host (rarely needed).
## (default: https://members.easynews.com)
# EASYNEWS_BASE_URL=https://members.easynews.com

## FULL override of the search URL — wins over EASYNEWS_SEARCH_API. Paste the
## exact request (e.g. grabbed from the 3.0 web UI's DevTools Network tab) using
## {base} {query} {page} {per_page} placeholders. The 3.0 request params are not
## officially documented, so if EASYNEWS_SEARCH_API=3.0 returns nothing, set the
## real request here. (default: empty — not used)
# EASYNEWS_SEARCH_URL_TEMPLATE={base}/3.0/api/search?gps={query}&pno={page}&pby={per_page}&fty%5B%5D=VIDEO

## Top-level JSON key holding the result rows, if the endpoint nests them under
## something other than "data". (default: data)
# EASYNEWS_RESULTS_KEY=data

## Log the active endpoint + per-request latency at INFO (handy while comparing
## 2.0 vs 3.0). The per-search summary line already shows [api 2.0]/[api 3.0].
## (default: false)
# EASYNEWS_LOG_LATENCY=true

## ──────────────────────────────────────────────────────────────────────────
## Result filtering
## ──────────────────────────────────────────────────────────────────────────
## Skip the title-matching filters (strict phrase, season/episode/year/quality,
## query-token subset). Validity checks (hash/ext, min size, virus, duration)
## always stay on. Turn on if your downstream client already matches and you'd
## rather receive everything Easynews returns. (default: false)
# EASYNEWS_DISABLE_FILTERS=false

## When the same file (identical hash) appears more than once, keep the NEWEST
## post instead of the first. Useful because an older post can be dead while a
## later re-post of the same file is alive. (Re-packed/re-encoded uploads have a
## different hash and are never merged, so they're unaffected.) (default: false)
# EASYNEWS_DEDUP_KEEP_NEWEST=true

## Keep results Easynews marks "password protected". That flag is a heuristic
## and often a false positive (on video results especially — Easynews returns
## runtime/codecs it could only read if the file weren't really locked), and the
## password, when real, is usually posted in an accompanying NFO/TXT. stremthru
## and AIOStreams keep these. Virus-flagged items are ALWAYS dropped regardless.
## (default: false — drop password-flagged; set true to include them)
EASYNEWS_ALLOW_PASSWORD=true

## Drop connector stopwords (and, of, the, a, an, in, for, on) from the query
## sent to Easynews. Easynews AND-matches every word, so a word that isn't in
## the release name zeroes out the search — e.g. a client expands "Escha & Logy"
## to "Escha and Logy" but releases are named "Escha..Logy" (no "and"). Filtering
## still uses the full token set, so precision is unchanged. (default: true)
# EASYNEWS_STRIP_STOPWORDS=true

## ──────────────────────────────────────────────────────────────────────────
## Extra metadata (newznab:attr) — audio/subtitle languages + codecs
## ──────────────────────────────────────────────────────────────────────────
## Language codes come from Easynews's JSON (subtitle_tracks / audio_tracks),
## so they only appear when the endpoint returns them (3.0 api + 2.0 dict form).
## AIOStreams reads the "subs" attr as subtitle languages and "language" as
## audio languages — e.g. lets it filter to Norwegian (nor) subtitles. Set to
## false to drop an attr. NOTE: if you route through NZBHydra2, it must be
## configured to pass these attributes through to the downstream client.
# EASYNEWS_META_SUBS=true     # subtitle langs -> attr "subs"    (default: true)
# EASYNEWS_META_AUDIO=true    # audio langs    -> attr "language"(default: true)
# EASYNEWS_META_CODECS=true   # codecs         -> attr "video"/"audio" (default: true)

## ──────────────────────────────────────────────────────────────────────────
## Extra search terms — surface language-tagged releases ranked deep
## ──────────────────────────────────────────────────────────────────────────
## Comma-separated. For each term the bridge ALSO runs "<query> <term>" next to
## the bare query and merges the results. Easynews AND-matches the term, so a
## tag like "nordic" pulls releases the bare relevance ranking buries past the
## first page right to the top. Great for always finding Nordic/Norwegian-subbed
## releases. Each term = one extra (concurrent) request per search.
## Example: EASYNEWS_EXTRA_TERMS=nordic, danish, norsk  (default: empty — off)
# EASYNEWS_EXTRA_TERMS=nordic

## Restrict results to releases whose subtitle tracks include one of these
## language codes (ISO 639-2, comma-separated; e.g. nor=Norwegian, swe, dan).
## STRICT: only keeps releases where Easynews actually reports a matching
## subtitle track, so releases whose subs Easynews didn't index are dropped.
## Best paired with EASYNEWS_EXTRA_TERMS=nordic so the subbed releases are
## fetched in the first place. Per-request override: add &subs=nor (or
## &subs=nor,swe) to the /api URL; &subs= (empty) disables it for that request.
## (default: empty — no subtitle restriction)
# EASYNEWS_REQUIRE_SUBS=nor

## ──────────────────────────────────────────────────────────────────────────
## Optional multi-page search (adds latency)
## ──────────────────────────────────────────────────────────────────────────
## Fetch extra pages (concurrently, deduped by hash) for more results on big
## queries — useful when a wanted release is ranked past the first page (e.g. a
## generic query like "From S01E04"). Pagination respects the response's
## numPages, so a single-page query costs ZERO extra calls even with a high
## MAX_PAGES — it only fetches pages that actually exist. Raising MAX_PAGES adds
## latency only on broad multi-page queries; keep SEARCH_BUDGET_SECONDS and your
## NZBHydra timeout high enough to cover the extra pages.
# EASYNEWS_PAGINATE=false   # (default: false)
# EASYNEWS_MAX_PAGES=1      # (default: 1 — first page only)

## after change run -> docker compose --profile easynews-indexer up -d
