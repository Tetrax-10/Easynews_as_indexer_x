## Copy this file to .env and fill in your credentials. Every variable below
## notes its (default: …). Commented-out lines show the default/example value;
## uncomment to change. After editing run:
##   docker compose --profile easynews-indexer up -d   (no rebuild needed)

## Easynews account. (default: none — REQUIRED, the server won't start without them)
EASYNEWS_USER=your_easynews_username
EASYNEWS_PASS=your_easynews_password

## API key Prowlarr/NZBHydra/Newznab clients use to authenticate to THIS server.
## Change it from the default. (default: testkey)
NEWZNAB_APIKEY=testkey

## Port the server listens on. (default: 8081)
PORT=8081


## ──────────────────────────────────────────────────────────────────────────
## Latency / hedging (read at container start)
## ──────────────────────────────────────────────────────────────────────────
## Hard cap on total time per search. Keep it below NZBHydra's indexer timeout
## (4 s). Raise only if you also raise Hydra's timeout. (default: 3.3)
SEARCH_BUDGET_SECONDS=3.8

## If Easynews hasn't answered within this, fire a parallel "hedge" request. Set
## it near your typical Easynews response time. Lower = recover from slow
## responses faster (more parallel load); higher = hedge less often. (default: 1.2)
SEARCH_HEDGE_AFTER_SECONDS=1.2

## Per-request read timeout in seconds — aborts a single hung connection.
## (default: 2.5)
# SEARCH_ATTEMPT_TIMEOUT_SECONDS=2.5

## Treat a fast, successful "0 results" as final and return immediately, instead
## of retrying 3x and idling out the budget (a real hang is an error, not an
## empty, and still retries). Keeps no-result queries ~0.3s instead of ~3.3s.
## Set false to restore the old 3-try-on-empty behaviour. (default: true)
# SEARCH_TRUST_EMPTY=true

## Keepalive — a background thread holds a warm TLS connection to Easynews open
## during idle gaps so the next real search skips the cold handshake. Set false
## to turn it off entirely (e.g. to minimise idle account activity); searches
## then just pay the handshake cost on the first request after an idle gap.
## (default: true)
# EASYNEWS_KEEPALIVE=true

## How often the keepalive thread wakes, and how many idle seconds (no real
## search traffic) must pass before it actually pings. (defaults: 45 / 40)
# EASYNEWS_KEEPALIVE_INTERVAL_SECONDS=45
# EASYNEWS_KEEPALIVE_IDLE_SECONDS=40

## Skip season-pack searches (a season with NO episode, e.g. "The Boys S05").
## Easynews rarely has real season packs, so enabling this stops them from
## polluting season searches — the query returns no results without hitting
## Easynews. Episode searches (S05E01) and movie searches are unaffected.
## (default: false — recommended true)
IGNORE_SEASON_PACKS=true


## ──────────────────────────────────────────────────────────────────────────
## Search endpoint
## ──────────────────────────────────────────────────────────────────────────
## Which Easynews search endpoint to use:
##   2.0 → /2.0/search/solr-search/  (proven)
##   3.0 → /3.0/api/search           (newer JSON api; leaner payload, ~3x smaller)
## (default: 2.0)
EASYNEWS_SEARCH_API=3.0


## ──────────────────────────────────────────────────────────────────────────
## Advanced search — server-side spam filter + extension whitelist
## ──────────────────────────────────────────────────────────────────────────
## When ON, the 2.0 endpoint switches to its "/advanced" variant (st=adv), which
## lets Easynews filter spam (spamf) and non-whitelisted extensions (fex) BEFORE
## results reach this bridge — fewer junk rows to map/dedup. This is what the
## upstream easynews-plus-plus Stremio addon uses. PROVEN on api 2.0. On api 3.0
## the same params are sent but Easynews may ignore them, so A/B test it — the
## per-search log shows [api 3.0+adv] when this is on. (default: false)
EASYNEWS_ADVANCED_SEARCH=true

## (advanced only) Drop Easynews-flagged spam server-side (spamf=1).
## Defaults ON whenever EASYNEWS_ADVANCED_SEARCH is on. (default: follows advanced)
# EASYNEWS_SPAM_FILTER=true

## (advanced only) Video-container whitelist sent as fex=. Comma-separated, no
## dots. Empty = don't send fex (Easynews returns any video container).
## (default: m4v,3gp,mov,divx,xvid,wmv,avi,mpg,mpeg,mp4,mkv,avc,flv,webm)
EASYNEWS_FILE_EXTENSIONS=m4v,3gp,mov,divx,xvid,wmv,avi,mpg,mpeg,mp4,mkv,avc,flv,webm


## ──────────────────────────────────────────────────────────────────────────
## Result sorting (multi-level)
## ──────────────────────────────────────────────────────────────────────────
## Easynews ranks results by up to three sort keys. Leaving these unset sends
## only the primary key the bridge already uses (relevance). Set SORT_1 to
## override the primary field, and SORT_2/SORT_3 to add tie-breakers.
##   field: relevance | dsize (size) | dtime (date posted) | dsubject
##   *_DIR: -  = descending (default)   |   +  = ascending
## Configured below for "biggest, then most-relevant, then newest".
EASYNEWS_SORT_1=dsize
EASYNEWS_SORT_1_DIR=-
EASYNEWS_SORT_2=relevance
EASYNEWS_SORT_2_DIR=-
EASYNEWS_SORT_3=dtime
EASYNEWS_SORT_3_DIR=-


## ──────────────────────────────────────────────────────────────────────────
## Result filtering
## ──────────────────────────────────────────────────────────────────────────
## Skip the title-matching filters (strict phrase, season/episode/year/quality,
## query-token subset). Validity checks (hash/ext, min size, virus, duration)
## always stay on. Turn on if your downstream client already matches and you'd
## rather receive everything Easynews returns. (default: false)
# EASYNEWS_DISABLE_FILTERS=false

## Minimum real-video duration, in seconds. Easynews is full of short preview/
## sample clips — many run 2–5 min and sail past a 60s floor, showing up as junk
## "releases" a client may grab then fail on. Raise to ~360 (6 min) to cut clip
## noise; lower only if you index very short content (music videos, shorts).
## (default: 60)
# EASYNEWS_MIN_DURATION_SECONDS=360

## When the same file (identical hash) appears more than once, keep the NEWEST
## post instead of the first. Useful because an older post can be dead while a
## later re-post of the same file is alive. (Re-packed/re-encoded uploads have a
## different hash and are never merged, so they're unaffected.) (default: false)
EASYNEWS_DEDUP_KEEP_NEWEST=true

## Keep results Easynews marks "password protected". That flag is a heuristic
## and often a false positive (on video results especially — Easynews returns
## runtime/codecs it could only read if the file weren't really locked), and the
## password, when real, is usually posted in an accompanying NFO/TXT. stremthru
## and AIOStreams keep these. Virus-flagged items are ALWAYS dropped regardless.
## (default: false — drop password-flagged; set true to include them)
EASYNEWS_ALLOW_PASSWORD=true

## Drop connector stopwords (and, of, the, a, an, in, for, on) from the query
## sent to Easynews. Easynews AND-matches every word, so a word that isn't in
## the release name zeroes out the search — e.g. a client expands "Escha & Logy"
## to "Escha and Logy" but releases are named "Escha..Logy" (no "and"). Filtering
## still uses the full token set, so precision is unchanged. (default: true)
# EASYNEWS_STRIP_STOPWORDS=true

# Include a direct Easynews HTTPS download URL in each search result.
# The URL is exposed via the RSS <comments> field for clients that support it.
# Default: true
# EASYNEWS_INCLUDE_DIRECT_URL=true

## Transliterate Norwegian letters to their ASCII digraphs: ø→oe, å→aa, æ→ae
## (uppercase too). Releases are routinely posted ASCII-folded — a film titled
## "Trøst" is uploaded as "Troest" — so an accented query AND-matches nothing on
## Easynews. This folds the outbound query AND both sides of the title filters,
## so the folded query finds the ASCII release and the result isn't then dropped.
## Only touches æ/ø/å, so non-Norwegian queries are unaffected. (default: false)
EASYNEWS_TRANSLITERATE_NORWEGIAN=true

## Per-title query overrides — rewrite a specific search TITLE to the exact form
## a release is posted under. Runs IN FRONT of the transliteration above, on the
## title only; season/episode/year still carry over, and the rewrite feeds BOTH
## the outbound query AND the title filters (so a rename doesn't then reject every
## result). Matching is case-insensitive against the folded, lowercased title your
## client sends (AIOStreams folds å→a, German ü→ue, etc.), so write match keys in
## that form. Write replacements ASCII-folded (aa/oe/ae) too — or, with
## EASYNEWS_TRANSLITERATE_NORWEGIAN=true, write real å/ø/æ and let the fold convert.
## Rules are separated by ' ;; ' (or newlines), each is 'match => replacement',
## tried in order — the FIRST match wins. Match syntax:
##   norsemen => Vikingane           replace the phrase (episode etc. carry over)
##   temptation island* =>           starts-with: keep "Temptation Island", drop the rest
##   *verfuehrung im paradies =>      ends-with:   keep the trailing part, drop the rest
## A '*' marks the side to DROP; an empty replacement on a '*' rule keeps the
## literal you typed (so mind its casing). Multi-rule example:
##   EASYNEWS_QUERY_REPLACE=norsemen => Vikingane ;; temptation island* =>
## (default: empty — off)
EASYNEWS_QUERY_REPLACE=ikke lov a le pa hytta => Ikke lov aa le paa hytta


## ──────────────────────────────────────────────────────────────────────────
## Extra metadata (newznab:attr) — audio/subtitle languages + codecs
## ──────────────────────────────────────────────────────────────────────────
## Language codes come from Easynews's JSON (subtitle_tracks / audio_tracks),
## so they only appear when the endpoint returns them (3.0 api + 2.0 dict form).
## AIOStreams reads the "subs" attr as subtitle languages and "language" as
## audio languages — e.g. lets it filter to Norwegian (nor) subtitles. Set to
## false to drop an attr. NOTE: if you route through NZBHydra2, it must be
## configured to pass these attributes through to the downstream client.
# EASYNEWS_META_SUBS=true     # subtitle langs -> attr "subs"    (default: true)
# EASYNEWS_META_AUDIO=true    # audio langs    -> attr "language"(default: true)
# EASYNEWS_META_CODECS=true   # codecs         -> attr "video"/"audio" (default: true)
# EASYNEWS_META_BITRATE=true  # video bitrate  -> attr "bitrate" e.g. "12.72 Mbps" (from raw bps, 2 dp; more precise than Easynews's whole-Mbps prettyBps) (default: true)
# EASYNEWS_META_GROUP=true    # usenet group   -> attr "group"   (default: true)
# EASYNEWS_META_PASSWORD=true # password flag  -> attr "password" ("1"/"0") (default: true)


## ──────────────────────────────────────────────────────────────────────────
## Extra search terms — surface language-tagged releases ranked deep
## ──────────────────────────────────────────────────────────────────────────
## Comma-separated. For each term the bridge ALSO runs "<query> <term>" next to
## the bare query and merges the results. Easynews AND-matches the term, so a
## tag like "nordic" pulls releases the bare relevance ranking buries past the
## first page right to the top. Great for always finding Nordic/Norwegian-subbed
## releases. Each term = one extra (concurrent) request per search.
## (default: empty — off)
# EASYNEWS_EXTRA_TERMS=nordic, danish, norsk

## Run EASYNEWS_EXTRA_TERMS only when the bare query returns 0 results, instead
## of alongside every search. Saves the extra request(s) on queries that already
## found something — set true if you only want the term boost as a last resort.
## (default: false — extra terms run on every search)
# EASYNEWS_EXTRA_TERMS_FALLBACK_ONLY=true

## Restrict results to releases whose subtitle tracks include one of these
## language codes (ISO 639-2, comma-separated; e.g. nor=Norwegian, swe, dan).
## STRICT: only keeps releases where Easynews actually reports a matching
## subtitle track, so releases whose subs Easynews didn't index are dropped.
## Best paired with EASYNEWS_EXTRA_TERMS=nordic so the subbed releases are
## fetched in the first place. Per-request override: add &subs=nor (or
## &subs=nor,swe) to the /api URL; &subs= (empty) disables it for that request.
## (default: empty — no subtitle restriction)
# EASYNEWS_REQUIRE_SUBS=nor


## ──────────────────────────────────────────────────────────────────────────
## 0-result fallback — alternate spellings + alternate titles (#5/#6)
## ──────────────────────────────────────────────────────────────────────────
## A "last resort" stage: ONLY when the primary search returns nothing, run a
## small set of backup queries built from alternate ASCII spellings of the title
## and curated alternate titles, then return whatever they find. Because it only
## fires on a 0-result query, it costs zero extra Easynews requests on the common
## case where the bare search already worked. Master switch. (default: false)
# EASYNEWS_FALLBACK_SEARCH=true

## Include alternate ASCII spellings in the backup. Generalised beyond Norwegian:
## Nordic + German digraph (ø→oe, å→aa, æ→ae, ä→ae, ö→oe, ü→ue, ß→ss), bare-vowel
## (ø→o, å→a, ü→u …) and a full accent strip (José→Jose, Köln→Koln, Tromsø→Tromso).
## A title with no special characters produces no variants (no wasted query).
## (default: true when EASYNEWS_FALLBACK_SEARCH is on)
# EASYNEWS_FALLBACK_TRANSLITERATE=true

## Include curated aliases from the custom-titles file (e.g. "Walking Dead" ->
## "The Walking Dead", "Norsemen" -> "Vikingane"). Aliases are also spelling-
## folded for thoroughness. (default: true when EASYNEWS_FALLBACK_SEARCH is on)
# EASYNEWS_FALLBACK_ALT_TITLES=true

## Path to the alternate-title JSON (canonical -> [aliases]). Same format as the
## upstream easynews-plus-plus custom-titles.json. (default: custom-titles.json)
# EASYNEWS_CUSTOM_TITLES_FILE=custom-titles.json

## Cap on how many backup queries fire (resource guard), and the wall-clock
## budget for the whole backup stage (it runs them concurrently, single-shot).
## NOTE: the backup runs AFTER the primary, so on a 0-result query total time can
## approach SEARCH_BUDGET_SECONDS + this. If you route through NZBHydra2, keep its
## indexer timeout above the sum. (defaults: 6 / 4.0)
# EASYNEWS_FALLBACK_MAX_QUERIES=6
# EASYNEWS_FALLBACK_BUDGET_SECONDS=4.0


## ──────────────────────────────────────────────────────────────────────────
## Search-result cache (#4)
## ──────────────────────────────────────────────────────────────────────────
## Cache the final result list per distinct query for this many seconds, so the
## constant repeat polling from Prowlarr/Sonarr/Radarr (RSS sync, re-runs, multi-
## app) is served from memory instead of re-hitting Easynews. Keep it SHORT — too
## long and a just-posted release stays invisible until the entry expires.
## 0 = caching off (unchanged behaviour). Recommended: 60–180. (default: 0)
# EASYNEWS_CACHE_TTL_SECONDS=120

## Max distinct queries held in the cache; oldest are evicted first (LRU).
## (default: 512)
# EASYNEWS_CACHE_MAX_ENTRIES=512


## ──────────────────────────────────────────────────────────────────────────
## Optional multi-page search (adds latency)
## ──────────────────────────────────────────────────────────────────────────
## Fetch extra pages (concurrently, deduped by hash) for more results on big
## queries — useful when a wanted release is ranked past the first page (e.g. a
## generic query like "From S01E04"). Pagination respects the response's
## numPages, so a single-page query costs ZERO extra calls even with a high
## MAX_PAGES — it only fetches pages that actually exist. Raising MAX_PAGES adds
## latency only on broad multi-page queries; keep SEARCH_BUDGET_SECONDS and your
## NZBHydra timeout high enough to cover the extra pages.
# EASYNEWS_PAGINATE=false   # (default: false)
# EASYNEWS_MAX_PAGES=1      # (default: 1 — first page only)


## ══════════════════════════════════════════════════════════════════════════
## DEVELOPER / DEBUG — overrides + diagnostics. Most setups never touch these.
## ══════════════════════════════════════════════════════════════════════════

## Override the Easynews host (rarely needed).
## (default: https://members.easynews.com)
# EASYNEWS_BASE_URL=https://members.easynews.com

## FULL override of the search URL — wins over EASYNEWS_SEARCH_API. Paste the
## exact request (e.g. grabbed from the 3.0 web UI's DevTools Network tab) using
## {base} {query} {page} {per_page} placeholders. The 3.0 request params are not
## officially documented, so if EASYNEWS_SEARCH_API=3.0 returns nothing, set the
## real request here. (default: empty — not used)
# EASYNEWS_SEARCH_URL_TEMPLATE={base}/3.0/api/search?gps={query}&pno={page}&pby={per_page}&fty%5B%5D=VIDEO

## Top-level JSON key holding the result rows, if the endpoint nests them under
## something other than "data". (default: data)
# EASYNEWS_RESULTS_KEY=data

## Log the active endpoint + per-request latency at INFO (handy while comparing
## 2.0 vs 3.0, or checking whether advanced search shows [api 3.0+adv]). The
## per-search summary line already shows [api 2.0]/[api 3.0]. (default: false)
EASYNEWS_LOG_LATENCY=true


## after change run -> docker compose --profile easynews-indexer up -d
