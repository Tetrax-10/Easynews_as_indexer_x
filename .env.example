## Copy this file to .env and fill in your credentials

EASYNEWS_USER=your_easynews_username
EASYNEWS_PASS=your_easynews_password

## API key used by Prowlarr/Newznab clients to authenticate to this server
NEWZNAB_APIKEY=testkey

## Optional: override server port (default 8081)
# PORT=8081

## Hard cap on total time per search. Keep it below NZBHydra's indexer timeout (4 s). Raise only if you also raise Hydra's timeout. 
SEARCH_BUDGET_SECONDS=3.3

## If Easynews hasn't answered within this, fire a parallel "hedge" request. Set it near your typical Easynews response time. 
## Lower = recover from slow responses faster (more parallel load); higher = hedge less often.
SEARCH_HEDGE_AFTER_SECONDS=1.2

## Per-request read timeout in seconds — aborts a single hung connection.
SEARCH_ATTEMPT_TIMEOUT_SECONDS=2.5

## Skip season-pack searches (a season with NO episode, e.g. "The Boys S05").
## Easynews rarely has real season packs, so enabling this stops them from
## polluting season searches — the query returns no results without hitting
## Easynews. Episode searches (S05E01) and movie searches are unaffected.
IGNORE_SEASON_PACKS=true

## ──────────────────────────────────────────────────────────────────────────
## Search endpoint selection (for A/B benchmarking endpoint speed)
## ──────────────────────────────────────────────────────────────────────────
## Which Easynews search endpoint to use:
##   2.0 → /2.0/search/solr-search/  (proven, default)
##   3.0 → /3.0/api/search           (newer JSON api; leaner payload, ~3x smaller)
## Switch, then `docker compose --profile easynews-indexer up -d` — no rebuild.
# EASYNEWS_SEARCH_API=2.0

## Override the Easynews host (rarely needed).
# EASYNEWS_BASE_URL=https://members.easynews.com

## FULL override of the search URL — wins over EASYNEWS_SEARCH_API. Paste the
## exact request (e.g. grabbed from the 3.0 web UI's DevTools Network tab) using
## {base} {query} {page} {per_page} placeholders. The 3.0 request params are not
## officially documented, so if EASYNEWS_SEARCH_API=3.0 returns nothing, set the
## real request here.
# EASYNEWS_SEARCH_URL_TEMPLATE={base}/3.0/api/search?gps={query}&pno={page}&pby={per_page}&fty%5B%5D=VIDEO

## If the chosen endpoint nests result rows under a key other than "data".
# EASYNEWS_RESULTS_KEY=data

## Log the active endpoint + per-request latency at INFO (handy while comparing
## 2.0 vs 3.0). The per-search summary line already shows [api 2.0]/[api 3.0].
# EASYNEWS_LOG_LATENCY=true

## ──────────────────────────────────────────────────────────────────────────
## Optional: skip the title-matching filters (strict phrase, season/episode/
## year/quality, query-token subset). Validity checks (hash/ext, min size,
## virus/password/duration) always stay on. Turn on if your downstream client
## already matches and you'd rather receive everything Easynews returns.
# EASYNEWS_DISABLE_FILTERS=false

## ──────────────────────────────────────────────────────────────────────────
## Extra metadata (newznab:attr) — audio/subtitle languages + codecs
## ──────────────────────────────────────────────────────────────────────────
## Language codes come from Easynews's JSON (subtitle_tracks / audio_tracks),
## so they only appear when the endpoint returns them (3.0 api + 2.0 dict form).
## AIOStreams reads the "subs" attr as subtitle languages and "language" as
## audio languages — e.g. lets it filter to Norwegian (nor) subtitles. Default
## on; set to false to drop an attr. NOTE: if you route through NZBHydra2, it
## must be configured to pass these attributes through to the downstream client.
# EASYNEWS_META_SUBS=true     # subtitle languages  -> newznab:attr name="subs"
# EASYNEWS_META_AUDIO=true    # audio languages     -> newznab:attr name="language"
# EASYNEWS_META_CODECS=true   # video/audio codecs  -> newznab:attr name="video"/"audio"

## ──────────────────────────────────────────────────────────────────────────
## Optional multi-page search (OFF by default — it adds latency)
## ──────────────────────────────────────────────────────────────────────────
## Fetch extra pages (concurrently, deduped by hash) for more results on big
## queries. Only enable if you've also raised SEARCH_BUDGET_SECONDS and your
## NZBHydra timeout, or it will blow the budget and return 0 results.
# EASYNEWS_PAGINATE=false
# EASYNEWS_MAX_PAGES=1

## after change run -> docker compose --profile easynews-indexer up -d
