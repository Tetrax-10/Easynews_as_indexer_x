## Copy this file to .env and fill in your credentials

EASYNEWS_USER=your_easynews_username
EASYNEWS_PASS=your_easynews_password

## API key used by Prowlarr/Newznab clients to authenticate to this server
NEWZNAB_APIKEY=testkey

## Optional: override server port (default 8081)
# PORT=8081

## Hard cap on total time per search. Keep it below NZBHydra's indexer timeout (4 s). Raise only if you also raise Hydra's timeout. 
SEARCH_BUDGET_SECONDS=3.3

## If Easynews hasn't answered within this, fire a parallel "hedge" request. Set it near your typical Easynews response time. 
## Lower = recover from slow responses faster (more parallel load); higher = hedge less often.
SEARCH_HEDGE_AFTER_SECONDS=1.2

## Per-request read timeout in seconds — aborts a single hung connection.
SEARCH_ATTEMPT_TIMEOUT_SECONDS=2.5

## Skip season-pack searches (a season with NO episode, e.g. "The Boys S05").
## Easynews rarely has real season packs, so enabling this stops them from
## polluting season searches — the query returns no results without hitting
## Easynews. Episode searches (S05E01) and movie searches are unaffected.
IGNORE_SEASON_PACKS=true

## after change run -> docker compose --profile easynews-indexer up -d
